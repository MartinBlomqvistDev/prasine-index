# Prasine Index — environment variable reference
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string using the asyncpg driver.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://prasine:prasine@localhost:5432/prasine_index

# Connection pool tuning. Defaults are suitable for single-process deployment.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Set to "true" to echo all SQL statements to stdout. Development only.
DB_ECHO=false

# Set to "true" in test environments. Disables connection pooling (NullPool)
# so test teardown can fully close all connections.
TESTING=false

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-...

# Model identifiers used by each LLM-backed agent.
EXTRACTION_MODEL=claude-opus-4-6
JUDGE_MODEL=claude-opus-4-6
REPORT_MODEL=claude-opus-4-6

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Logging level for the Prasine Index process. Valid values: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# External data sources
# ---------------------------------------------------------------------------

# EU ETS / EUTL — no API key required; open data.
# Override only if the EUTL base URL changes.
EU_ETS_BASE_URL=https://ec.europa.eu/clima/ets

# CDP Open Data — bulk CSV download; no API key required for open dataset.
CDP_OPEN_DATA_URL=https://data.cdp.net

# EUR-Lex REST API — open access, no authentication required.
EUR_LEX_API_URL=https://eur-lex.europa.eu/rest

# EU Transparency Register — open access.
EU_TRANSPARENCY_REGISTER_URL=https://ec.europa.eu/transparencyregister/public
