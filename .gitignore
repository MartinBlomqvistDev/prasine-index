# Prasine Index — .gitignore

# Private planning docs and internal working files
PRODUCT_ROADMAP.md
DEV_LOG.md
AGENTS.md
WEB_AUDIT_HANDOFF_CLAUDE.md

# ---------------------------------------------------------------------------
# Environment and secrets — never commit
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
!web/lib/
wheels/

# ---------------------------------------------------------------------------
# Virtual environment
# ---------------------------------------------------------------------------
.venv/
venv/
ENV/
env/

# ---------------------------------------------------------------------------
# Testing and coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ---------------------------------------------------------------------------
# IDE and editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------
CLAUDE.md
.claude/

# ---------------------------------------------------------------------------
# Pipeline sub-reports — numbered artifacts, only canonicals belong in the repo
# ---------------------------------------------------------------------------
docs/reports/*-[0-9].md
# Development / experimental report scratch — never belongs in the repo
docs/reports/_dev/

# ---------------------------------------------------------------------------
# Logs and local data
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Scratch / temp files
# ---------------------------------------------------------------------------
tmp_*.txt
tmp_*.csv
operators_daily.csv

# ---------------------------------------------------------------------------
# Large data files — downloaded by refresh_*.py scripts, not in version control
# ---------------------------------------------------------------------------
EUTL24/
eutl_2024_202410/
data/*.csv
data/enforcement_flags.json
data/enforcement_last_run.json
data/*.xlsx
data/*.xls
data/*.pdf
data/*.txt
data/*.accdb
data/*.zip
data/eea_t_*/
data/JRC/
data/GEM-EGT-Pipelines-*/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
*.sqlite3
*.db

# ---------------------------------------------------------------------------
# Alembic migrations (generated — commit deliberately)
# alembic/versions/ is intentionally NOT ignored
# ---------------------------------------------------------------------------
alembic.ini.local

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
MANIFEST
