# Prasine Index — .gitignore

# ---------------------------------------------------------------------------
# Environment and secrets — never commit
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/

# ---------------------------------------------------------------------------
# Virtual environment
# ---------------------------------------------------------------------------
.venv/
venv/
ENV/
env/

# ---------------------------------------------------------------------------
# Testing and coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ---------------------------------------------------------------------------
# IDE and editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------
CLAUDE.md

# ---------------------------------------------------------------------------
# Logs and local data
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Large data files — downloaded by refresh_*.py scripts, not in version control
# ---------------------------------------------------------------------------
EUTL24/
eutl_2024_202410/
data/*.csv
data/*.xlsx
data/*.xls
data/*.pdf
data/*.txt
data/*.accdb
data/eea_t_*/

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
*.sqlite3
*.db

# ---------------------------------------------------------------------------
# Alembic migrations (generated — commit deliberately)
# alembic/versions/ is intentionally NOT ignored
# ---------------------------------------------------------------------------
alembic.ini.local

# ---------------------------------------------------------------------------
# Distribution / packaging
# ---------------------------------------------------------------------------
MANIFEST
